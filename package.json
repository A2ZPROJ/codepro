{
  "name": "codepro",
  "version": "2.84.39",
  "description": "Nexus â€” GestÃ£o Integrada A2Z Projetos",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "embed-civil3d": "node scripts/embed-civil3d.js",
    "precompile": "node scripts/embed-civil3d.js && node scripts/compile-obfuscate.js && node scripts/obfuscate-html.js",
    "postrestore": "node scripts/restore-source.js",
    "build": "node scripts/build.js",
    "build:publish": "node scripts/build.js --publish",
    "postbuild:publish": "node scripts/nexus-office-push.js",
    "atualizar": "node scripts/atualizar-nexus.js",
    "publicar:testar": "node scripts/build.js --publish && node scripts/nexus-office-push.js && node scripts/atualizar-nexus.js",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.a2zprojetos.codepro",
    "productName": "Nexus",
    "copyright": "Copyright Â© 2026 A2Z Projetos",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/xlsx/**",
      "node_modules/exceljs/**"
    ],
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json",
      "!**/*.src",
      "!**/*.jsc",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "scripts/orcamento",
        "to": "scripts/orcamento",
        "filter": [
          "**/*.py"
        ]
      },
      {
        "from": "scripts/orcamento-elevatoria",
        "to": "scripts/orcamento-elevatoria",
        "filter": [
          "**/*.py",
          "assets/**/*",
          "!_gen_form_schema.py",
          "!**/__pycache__/**",
          "!configs/**"
        ]
      },
      {
        "from": "scripts/memorial",
        "to": "scripts/memorial",
        "filter": [
          "**/*.py",
          "assets/**/*",
          "cache/**/*",
          "!sample_amapora/**"
        ]
      },
      {
        "from": "scripts/rh",
        "to": "scripts/rh",
        "filter": [
          "**/*.py"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nexus",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "A2ZPROJ",
      "repo": "codepro",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.100",
    "@sentry/electron": "^7.14.0",
    "@supabase/supabase-js": "^2.102.1",
    "adm-zip": "^0.5.17",
    "bytenode": "^1.5.7",
    "docx": "^9.6.1",
    "docx-preview": "^0.3.7",
    "docxtemplater": "^3.68.4",
    "electron-updater": "^6.1.7",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "pdf-to-png-converter": "^3.18.0",
    "pdfmake": "^0.3.7",
    "pizzip": "^3.2.0",
    "shapefile": "^0.6.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@sentry/cli": "^2.58.6",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "javascript-obfuscator": "^5.4.1",
    "vitest": "^1.6.0"
  },
  "author": {
    "name": "A2Z Projetos",
    "email": "lucas.abdala@a2zprojetos.com.br"
  },
  "allowScripts": {
    "@sentry/cli@2.58.6": true
  }
}
