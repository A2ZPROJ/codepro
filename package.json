{
  "name": "codepro",
  "version": "1.9.26",
  "description": "Nexus — Gestão de Projetos A2Z Projetos",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:publish": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.a2zprojetos.codepro",
    "productName": "Nexus",
    "copyright": "Copyright © 2026 A2Z Projetos",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nexus",
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "A2ZPROJ",
      "repo": "codepro",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.102.1",
    "electron-updater": "^6.1.7",
    "exceljs": "^4.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  },
  "author": {
    "name": "A2Z Projetos",
    "email": "lucas.abdala@a2zprojetos.com.br"
  }
}
